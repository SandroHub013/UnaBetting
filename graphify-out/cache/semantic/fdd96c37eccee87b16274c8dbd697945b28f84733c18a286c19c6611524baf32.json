{"nodes": [{"id": "build_features_build_all_features", "label": "build_all_features \u2014 Feature Pipeline Orchestrator", "file_type": "code", "source_file": "src/features/build_features.py", "source_location": "L25-L100", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "build_features_add_implied_probabilities", "label": "_add_implied_probabilities (de-vigged market prob + has_odds)", "file_type": "code", "source_file": "src/features/build_features.py", "source_location": "L102-L140", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "build_features_add_contextual_features", "label": "_add_contextual_features (context, totals, auto-diff)", "file_type": "code", "source_file": "src/features/build_features.py", "source_location": "L143-L262", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "build_features_add_clutch_features", "label": "_add_clutch_features (merge_asof clutch stats)", "file_type": "code", "source_file": "src/features/build_features.py", "source_location": "L266-L331", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "build_features_add_weather_features", "label": "_add_weather_features (tourney weather merge)", "file_type": "code", "source_file": "src/features/build_features.py", "source_location": "L333-L357", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "build_features_prepare_feature_matrix", "label": "_prepare_feature_matrix (leak filter, winner-POV target)", "file_type": "code", "source_file": "src/features/build_features.py", "source_location": "L359-L476", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_has_odds_flag", "label": "has_odds Flag", "file_type": "rationale", "source_file": "src/features/build_features.py", "source_location": "L129-L137", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Added 2026-06-09 because rows without odds carry a 0.5/0.5 implied-prob sentinel fill that passed dropna and produced phantom 2.00 odds in the backtest; the perspective-symmetric flag lets the model and downstream consumers distinguish real market information from the fill without re-deriving from raw odds columns. Only ~32% of historical rows (~65% recent) have real odds."}, {"id": "concept_winner_pov_leak", "label": "Winner-POV Row Leakage", "file_type": "rationale", "source_file": "src/features/build_features.py", "source_location": "L456-L463", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Feature rows are stored winner-POV (target=1 always; w_ side is the actual winner). Any consumer that does not flip ~50% of rows leaks the label: betting on p1 auto-wins. w_/l_ feature pairs must stay paired (the 2026-05-22 unpaired-columns leak inflated acc to 77.8% / ROI +46%, fixed by _enforce_perspective_pairs) and diff_ features carry winner-tilt sign pre-flip. Honest feature tilt is ~0.55-0.66; >0.75 is a leak suspect."}, {"id": "concept_implied_prob_feature", "label": "Market Implied Probability Feature (de-vigged B365\u2192PS\u2192Avg)", "file_type": "rationale", "source_file": "src/features/build_features.py", "source_location": "L102-L140", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Bookmaker implied probability with the overround removed (B365 primary, Pinnacle secondary, Avg fallback) acts as a powerful SOTA baseline feature, transforming the model into a differential error-corrector on top of the market. Missing values are filled with the 0.5/0.5 coin-flip sentinel to keep historical rows \u2014 which is exactly why the has_odds flag exists."}], "edges": [{"source": "build_features_build_all_features", "target": "elo_process_matches", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "src/features/build_